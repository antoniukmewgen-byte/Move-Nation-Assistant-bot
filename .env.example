# Бот, отриманий у @BotFather (MoveNation_Assistant_bot)
BOT_TOKEN=123456:ABC-your-bot-token

# Дані для MTProto-авторизації (my.telegram.org -> API development tools)
API_ID=123456
API_HASH=your_api_hash

# Username бота без @ (використовується, щоб додати бота адміном у нові групи)
BOT_USERNAME=MoveNation_Assistant_bot

# Ключ шифрування сесій користувачів (Fernet).
# Згенерувати: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=your_generated_fernet_key

# База даних
DATABASE_URL=sqlite+aiosqlite:///./data/movenation.db

# Шлях до дефолтного лого групи
DEFAULT_LOGO_PATH=./assets/default_logo.png

# Інтервал нагадувань, хв
REMINDER_INTERVAL_MINUTES=5

# Backend API (для Mini App)
API_HOST=127.0.0.1
API_PORT=8000
WEBAPP_URL=http://127.0.0.1:8000/miniapp/index.html

# Список джерел (через кому), яким дозволено CORS-запити до API.
# Залиш порожнім (за замовчуванням), якщо Mini App віддається з того ж
# FastAPI-застосунку — same-origin запити CORS-заголовків не потребують.
CORS_ALLOWED_ORIGINS=

# Скільки секунд лишається валідним підпис Telegram WebApp initData
INIT_DATA_MAX_AGE_SECONDS=86400

# Рівень логування (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
